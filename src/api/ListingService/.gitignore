# Arquivo .gitignore padrão e robusto para .NET, C#, Visual Studio, VS Code e xUnit.
# Gerado com base nas recomendações oficiais da Microsoft e do GitHub.

# # # # # # # # # # # #
# C# / .NET Core      #
# # # # # # # # # # # #

# Pastas de output da compilação
bin/
obj/

# Arquivos de log
*.log
logs/

# Arquivos gerados pelo Tye
.tye/

# Artefatos do BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Variáveis de ambiente
.env

# # # # # # # # # # # #
# Visual Studio       #
# # # # # # # # # # # #

# Pasta de cache e configurações do Visual Studio (essencial ignorar)
.vs/

# Arquivos específicos do usuário (configurações locais, etc.)
*.user
*.suo
*.userosscache
*.sln.docstates

# Arquivos de build e cache
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf
ipch/

# Arquivos de resultados de teste
TestResult/
*.visualstate.xml
TestResult.xml

# Arquivos de cobertura de código
*.coverage
*.coveragexml

# Arquivos de backup do Visual Studio
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# # # # # # # # # # # # #
# Visual Studio Code  #
# # # # # # # # # # # # #

# Ignora a pasta .vscode exceto arquivos que devem ser compartilhados com a equipe
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Histórico local de arquivos do VS Code
.history/

# # # # # # # # # # # #
# Testes (xUnit, etc) #
# # # # # # # # # # # #

# Relatórios e logs de frameworks de teste e cobertura
*.trx
coverlet.json
coverage.cobertura.xml

# # # # # # # # # # # #
# Pacotes NuGet       #
# # # # # # # # # # # #

# Ignora a pasta de pacotes pois ela é restaurada pelo NuGet
**/[Pp]ackages/*
# Mas não ignora os alvos de build dentro dela
!**/[Pp]ackages/build/

# Arquivos gerados pelo NuGet v3
*.nuget.props
*.nuget.targets

# # # # # # # # # # # #
# Arquivos do S.O.    #
# # # # # # # # # # # #

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs