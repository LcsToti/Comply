# .env.example
# Copy this file to .env.development or .env.production and fill it with the actual values.

# 1. API BASE URL (Used BY AXIOS in all environments)
# Defines the API entry point for the frontend.
#
# In .env.development: Use the Vite proxy path.
# Ex: VITE_API_URL=/api
#
# In .env.production: Use the path where Nginx will route,
# whether it is a relative path or a full URL.
# Ex: VITE_API_URL=https://yoursite.dev/api/v1
VITE_API_URL=

# 2. PROXY TARGET (Used ONLY BY VITE in development)
# Defines the REAL backend address where the Vite proxy should redirect.
# This variable is ignored during the production build.
#
# In .env.development:
# Ex: VITE_PROXY_TARGET=http://localhost:9191/api/v1
VITE_PROXY_TARGET=